<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="API Automation Suite" parallel="false">

	<listeners>
		<!-- Allure Listener -->
		<listener class-name="io.qameta.allure.testng.AllureTestNg" />
	</listeners>
	<test name="Authentication API Tests">
		<classes>
			<class name="com.tgak.sms.tests.AuthenticationTest" />
		</classes>
	</test>
	<test name="Sign Up API Tests">
		<classes>
			<class name="com.tgak.sms.tests.SignUpUserTest" />
		</classes>
	</test>
</suite>